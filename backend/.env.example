# Origins permitidas pelo CORS (separadas por vírgula)
# Necessário apenas em desenvolvimento (front rodando em localhost:5173 separado do back-end)
# Em produção o front é servido pelo próprio FastAPI — CORS não se aplica
ALLOWED_ORIGINS=http://localhost:5173

# Duração máxima de vídeo aceita (segundos)
MAX_VIDEO_DURATION_SECONDS=30
